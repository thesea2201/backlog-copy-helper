{
  "manifest_version": 3,
  "name": "Backlog Utils",
  "version": "1.2.0",
  "description": "Utility toolkit for Backlog - copy issues, translate content, enhance workflow, and more",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.backlog.jp/*",
    "*://backlog.jp/*",
    "*://*.google.com/*",
    "*://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.backlog.jp/*",
        "*://backlog.jp/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
