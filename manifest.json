{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.4.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.backlog.jp/*",
    "*://backlog.jp/*",
    "*://*.google.com/*",
    "*://translate.googleapis.com/*",
    "*://*.chatgpt.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.backlog.jp/*",
        "*://backlog.jp/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
